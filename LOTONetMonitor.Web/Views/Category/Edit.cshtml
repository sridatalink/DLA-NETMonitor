@model LOTONetMonitor.Web.Models.Category.CategoryViewModel

@{
    ViewData["Title"] = "Edit Category - LOTO NET Monitor";
}

<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="page-title">
                <i class="bi bi-pencil-square"></i> Edit Category
            </h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" asp-action="Edit" asp-route-id="@Model.CategoryID" novalidate>
                    <input type="hidden" asp-for="CategoryID" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-circle"></i> Please fix the following errors:
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label"></label>
                        <input asp-for="CategoryName" class="form-control form-control-lg" />
                        <span asp-validation-for="CategoryName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>

                    <hr />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-danger bg-opacity-10">
            <div class="card-body">
                <h5 class="card-title text-danger">
                    <i class="bi bi-exclamation-triangle"></i> Danger Zone
                </h5>
                <p class="small text-muted mb-3">You can only delete this category if it has no devices assigned.</p>
                <a asp-action="Delete" asp-route-id="@Model.CategoryID" class="btn btn-outline-danger w-100">
                    <i class="bi bi-trash"></i> Delete This Category
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
